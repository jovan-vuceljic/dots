{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "leader": "ctrl+h",
    "commands": {
      "search": "ctrl+f",
      "agent-switch": "ctrl+a",
      "terminal": "ctrl+t",
      "clear": "ctrl+l"
    }
  },
  "theme": {
    "mode": "dark",
    "transparency": 0.8,
    "accent": "blue",
    "success": "green",
    "error": "red",
    "warning": "yellow"
  },
  "ui": {
    "sidebar": {
      "visible": true,
      "width": 30
    },
    "font_size": 14,
    "show_status_bar": true,
    "compact_mode": true
  }
}
